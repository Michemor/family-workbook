rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: checks whether the authenticated user belongs to a given family.
    function isFamilyMember(familyId) {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.familyId == familyId;
    }

    // ─── 1. USERS COLLECTION ──────────────────────────────────────────────────
    // Users can only read/write their own document and all subcollections
    // (e.g. ModuleResponses/{moduleId}/Responses/{contentId}).
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /{subcollection}/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ─── 2. FAMILIES COLLECTION ───────────────────────────────────────────────
    match /families/{familyId} {
      // Any authenticated user can create a family (needed for initial setup).
      allow create: if request.auth != null;

      // Read/Update: only members of this family.
      allow read, update: if request.auth != null && isFamilyMember(familyId);

      // Prevent accidental deletion of the entire family unit.
      allow delete: if false;

      // ── Family Members subcollection ──────────────────────────────────────
      match /familyMembers/{memberId} {
        allow create: if request.auth != null;
        allow read, update, delete: if request.auth != null && isFamilyMember(familyId);
      }
    }

    // ─── 3. MODULES COLLECTION (content library) ──────────────────────────────
    // The Modules collection is the weekly lesson catalogue managed via the
    // Firebase console. Any signed-in user can read; nobody writes from the app.
    match /Modules/{moduleId} {
      allow read: if request.auth != null;
      allow write: if false;

      // Subcollections: ModuleContent, InsightCards
      match /{subcollection}/{document=**} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    // ─── 4. FAMILY CHARTER COLLECTION ────────────────────────────────────────
    // FamilyCharter documents are keyed by UUID; each has a `familyId` field.
    // Only members of the matching family can read the charter and its clauses.
    match /FamilyCharter/{charterId} {
      allow read: if request.auth != null
                  && isFamilyMember(resource.data.familyId);
      allow write: if false;

      // Clauses subcollection
      match /Clauses/{clauseId} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    // ─── 5. GAMES COLLECTION ─────────────────────────────────────────────────
    // Games are managed in the Firebase console. Any signed-in user can read.
    match /Games/{gameId} {
      allow read: if request.auth != null;
      allow write: if false;

      match /{subcollection}/{document=**} {
        allow read: if request.auth != null;
        allow write: if false;
      }
    }

    // ─── DEFAULT DENY ─────────────────────────────────────────────────────────
    // Any path not explicitly matched above is denied.
    match /{document=**} {
      allow read: if false;
    }
  }
}